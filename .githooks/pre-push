#!/usr/bin/env bash

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [[ -n "${REPO_ROOT:-}" ]]; then
  cd "$REPO_ROOT"
fi

BRANCH=$(git branch --show-current 2>/dev/null)
[[ "$BRANCH" == studio/session* ]] && exit 0

if [[ -z "$BRANCH" ]]; then
  echo "PUSH BLOCKED: checkout a branch before pushing." >&2
  exit 1
fi

if [[ "$BRANCH" == "main" || "$BRANCH" == "master" ]]; then
  echo "PUSH BLOCKED: direct pushes to $BRANCH are not allowed." >&2
  exit 1
fi

if command -v gh >/dev/null 2>&1; then
  PR_BODY="$(gh pr view "$BRANCH" --json body -q .body 2>/dev/null || true)"
  if [[ -n "$PR_BODY" ]]; then
    if [[ ! "$PR_BODY" =~ ^Closes\ #[0-9]+$ ]]; then
      echo "" >&2
      echo "PUSH BLOCKED: PR body must contain exactly one closing reference, for example: Closes #123" >&2
      echo "" >&2
      exit 1
    fi
  fi
fi

changed_files=()
while IFS= read -r path; do
  [[ -n "$path" ]] || continue
  [[ -f "$path" ]] || continue
  changed_files+=("$path")
done < <(git diff --name-only origin/main...HEAD --)

echo "pre-push: checking formatting..." >&2
if [[ "${#changed_files[@]}" -gt 0 ]]; then
  bunx prettier --check --ignore-unknown "${changed_files[@]}"
else
  echo "pre-push: no changed files against origin/main; skipping formatting check." >&2
fi

echo "pre-push: checking TypeScript..." >&2
bunx tsc --noEmit --pretty false

echo "pre-push: running build..." >&2
bun run build

exit 0
