{
  "name": "calypso-weekly",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "test": "bun run packages/db/migrate.ts && bunx vitest run && bunx playwright test",
    "lint": "bunx eslint .",
    "format": "bunx prettier --write .",
    "dev": "bun run --filter '*' dev"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.40.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^2.0.0"
  }
}